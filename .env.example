# Site
NEXT_PUBLIC_SITE_URL=https://satoriwebsite.vercel.app

# GitHub (匿名 token,用 public_repo scope)
GITHUB_TOKEN=

# --- Phase 2 (Supabase 接好後必填) ---
# Project URL — Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://yiruoaerlrrbxnszomsf.supabase.co
# anon / public key — 同一頁,「Project API keys」第一條
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service_role secret key — 同一頁,「Project API keys」第二條(點 Reveal)
# 絕對不放 client side、不進 git。只在 server-only routes 讀(/api/news/ingest 等)
SUPABASE_SERVICE_ROLE_KEY=

# News ingestion(我們自己生一串長亂數即可,給 webhook 驗證用)
NEWS_INGEST_SECRET=

# --- Phase 3 才會用到 ---
# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@satoriai.lab
